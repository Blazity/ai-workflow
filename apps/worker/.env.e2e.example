# Target server
E2E_BASE_URL=https://your-staging.vercel.app

# Jira (scoped service-account Bearer token; routed through api.atlassian.com)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
JIRA_WEBHOOK_SECRET=
COLUMN_AI=AI
COLUMN_AI_REVIEW=AI Review
COLUMN_BACKLOG=Backlog

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Cron auth
CRON_SECRET=

# Upstash Redis
AI_WORKFLOW_KV_REST_API_URL=
AI_WORKFLOW_KV_REST_API_TOKEN=

# Vercel Deployment Protection bypass (optional, needed for preview URLs)
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Vercel Sandbox credentials for the e2e runner (Sandbox.list / Sandbox.create
# in e2e/helpers/sandbox.ts and us02). Set all three to use a long-lived PAT
# instead of re-pasting a rotating OIDC token from `vercel env pull`.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
