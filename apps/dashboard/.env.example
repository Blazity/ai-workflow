# Dashboard (Cockpit) — Next.js app that renders observability for the worker.
#
# The dashboard fetches the worker's read-only /api/v1/* API server-side (in
# React Server Components, never from the browser). Authentication is handled
# via Better Auth: the worker issues a `ba_session` cookie on login, and the
# dashboard replays it as `Authorization: Bearer <token>` on every server-side
# fetch. There is no shared bearer secret — no shared token.

# Base URL of the deployed worker (no trailing slash).
# Local dev against a local worker: http://localhost:3000
WORKER_BASE_URL=https://your-worker.vercel.app
