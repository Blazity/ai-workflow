# Dashboard (Cockpit) — Next.js app that renders observability for the worker.
#
# The dashboard holds no integration credentials of its own. It fetches the
# worker's read-only /api/v1/* API server-side (in React Server Components, never
# from the browser) and renders the result. It therefore needs just two things:
# where the worker lives, and the shared token that gates its API.

# Base URL of the deployed worker (no trailing slash).
# Local dev against a local worker: http://localhost:3000
WORKER_BASE_URL=https://your-worker.vercel.app

# Shared bearer secret — MUST match WORKER_API_TOKEN set on the worker deployment.
# Sent as `Authorization: Bearer <token>`; stays server-side (no NEXT_PUBLIC_).
# When unset or mismatched, the worker returns 401 and the dashboard falls back
# to its documented empty/N-A state instead of crashing.
# Generate with `openssl rand -hex 32`.
WORKER_API_TOKEN=
