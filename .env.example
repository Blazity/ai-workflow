DATABASE_URL=postgresql://blazebot:blazebot@localhost:5432/blazebot
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development
MAX_CONCURRENT_AGENTS=3

# Jira webhook HMAC secret (required — verifies X-Hub-Signature header)
JIRA_WEBHOOK_SECRET=

# Adapter configuration
ISSUE_TRACKER_KIND=jira
MESSAGING_KIND=slack
VCS_KIND=github

# Column name and job timeout
COLUMN_AI=AI
JOB_TIMEOUT_MS=600000

# Jira REST API (required for worker)
# JIRA_BASE_URL=https://yourteam.atlassian.net
# JIRA_USER_EMAIL=
# JIRA_API_TOKEN=

# GitHub (required for worker)
# GITHUB_TOKEN=
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=
GITHUB_BASE_BRANCH=main

# Anthropic (required for worker)
# ANTHROPIC_API_KEY=

# Column names
COLUMN_AI_REVIEW=AI Review
COLUMN_BACKLOG=Backlog

# Sandbox config
DOCKER_IMAGE=blazebot-sandbox
SANDBOX_MEMORY_MB=4096

# Docker Compose Postgres config
POSTGRES_USER=blazebot
POSTGRES_PASSWORD=blazebot
POSTGRES_DB=blazebot
