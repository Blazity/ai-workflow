DATABASE_URL=postgresql://blazebot:blazebot@localhost:5432/blazebot
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development
MAX_CONCURRENT_AGENTS=3

# Jira webhook HMAC secret (required — verifies X-Hub-Signature header)
JIRA_WEBHOOK_SECRET=

# Adapter configuration
ISSUE_TRACKER_KIND=jira
MESSAGING_KIND=slack
# Slack notifications (optional — if omitted, no notifications are sent)
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_DEFAULT_CHANNEL=C0123456789
VCS_KIND=github

# Column name and job config
COLUMN_AI=AI
JOB_TIMEOUT_MS=600000
JOB_MAX_RETRIES=3
JOB_BACKOFF_MS=30000

# Jira REST API (required for worker)
# JIRA_BASE_URL=https://yourteam.atlassian.net
# JIRA_USER_EMAIL=
# JIRA_API_TOKEN=

# GitHub (required for worker)
# GITHUB_TOKEN=
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=
GITHUB_BASE_BRANCH=main

# Claude Code OAuth token (required — generate with `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=
# Claude model override (defaults to claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Column names
COLUMN_AI_REVIEW=AI Review
COLUMN_BACKLOG=Backlog

# Polling fallback (missed webhook and stuck job detection)
JIRA_PROJECT_KEY=PROJ
POLL_INTERVAL_MS=300000
STUCK_JOB_THRESHOLD_MS=1200000

# Sandbox config
DOCKER_IMAGE=blazebot-sandbox
SANDBOX_MEMORY_MB=4096
# Developer mode (streams Claude Code output for docker logs -f inspection)
DEVELOPER_MODE=false

# Docker Compose Postgres config
POSTGRES_USER=blazebot
POSTGRES_PASSWORD=blazebot
POSTGRES_DB=blazebot
